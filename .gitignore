# ========== 后端部分 ==========
# 忽略编译后的可执行文件
*.exe
*.exe~
*.dll
*.so
*.dylib
bin/

# 忽略 Go 的依赖包存放区
vendor/

# 忽略本地的环境变量/配置文件（防密码泄露）
*.env
config.yml

# 忽略图片文件
uploads/

# ========== 前端部分 ==========
# 忽略依赖项
node_modules/

# 忽略打包构建产物
dist/
dist-ssr/

# 忽略 TypeScript 构建缓存
*.tsbuildinfo

# 忽略包管理器的错误日志
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ========== 通用部分 ==========
# 忽略开发工具生成的隐藏文件夹
.idea/
.vscode/

# 忽略 macOS 系统生成的隐藏文件
.DS_Store